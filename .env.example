# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Base URL used to build the embed <script> snippet. Public (safe to expose).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Security ---
# Salt for hashing visitor IPs (salt + sha256). Raw IPs are NEVER stored.
IP_HASH_SALT=dev-only-change-me

# --- Geo provider outage simulation (deterministic testing) ---
# When "true", that provider throws, forcing the fallback chain to the next one.
GEO_PROVIDER_1_DOWN=false
GEO_PROVIDER_2_DOWN=false
